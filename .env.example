# Copy to .env. Local development points at the LOCAL Supabase stack (npm run db:start).
# The local keys below are the CLI's fixed defaults — shared across all machines, not
# secrets — so this file works as-is for local content. Production values (the hosted
# project's URL + keys) are set in Vercel's env vars, never committed here.
PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_ACJWlzQHlZjBrEguHvfOxg_3BJgxAaH
# Local service-role key — run `npm run db:status` to get it. Not used by the app
# itself (only seeding / service-role tasks); left blank so no secret pattern is committed.
SUPABASE_SECRET_KEY=

# Google OAuth for LOCAL sign-in (read by `supabase start` for config.toml, not the app).
# Optional: only needed to exercise the real Google flow locally. Supply your own OAuth
# client's credentials; leave blank to skip local Google sign-in.
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=
SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET=

# Shared secret the /api/keepalive endpoint requires. In production, set the same value
# in Vercel; Vercel Cron sends it as `Authorization: Bearer <CRON_SECRET>`. Any value works.
CRON_SECRET=
