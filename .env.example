PUBLIC_SUPABASE_URL=REPLACE_SUPABASE_PROJECT_URL
PUBLIC_SUPABASE_PUBLISHABLE_KEY=REPLACE_SUPABASE_PUBLISHABLE_KEY
SUPABASE_SECRET_KEY=REPLACE_SUPABASE_SECRET_KEY

# Google OAuth credentials for the LOCAL Supabase stack (config.toml env() substitution).
# The hosted project reads its own copy from the Supabase dashboard, not from here.
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=REPLACE_GOOGLE_OAUTH_CLIENT_ID
SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET=REPLACE_GOOGLE_OAUTH_CLIENT_SECRET