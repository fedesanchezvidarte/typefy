{
	"name": "typefy",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"engines": {
		"node": "22.x"
	},
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync && husky",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"test:unit": "vitest",
		"test": "npm run test:unit -- --run && npm run test:e2e",
		"test:e2e": "playwright install && playwright test",
		"check:i18n": "node scripts/check-i18n-parity.js",
		"db:start": "supabase start",
		"db:stop": "supabase stop",
		"db:status": "supabase status",
		"db:reset": "supabase db reset",
		"db:seed:generate": "tsx scripts/generate-seed.ts",
		"db:types": "supabase gen types typescript --local > src/lib/database.types.ts && prettier --write src/lib/database.types.ts"
	},
	"lint-staged": {
		"*.{js,ts,svelte,json,md,css,html,yaml,yml}": "prettier --write"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@inlang/paraglide-js": "^2.18.2",
		"@playwright/test": "^1.60.0",
		"@sveltejs/adapter-vercel": "^6.3.3",
		"@sveltejs/kit": "^2.63.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/vite": "^4.3.0",
		"@types/node": "^24",
		"@vitest/browser-playwright": "^4.1.8",
		"eslint": "^10.4.1",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.19.0",
		"globals": "^17.6.0",
		"husky": "^9.1.7",
		"lint-staged": "^17.1.1",
		"playwright": "^1.60.0",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^4.1.0",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"supabase": "^2.109.1",
		"svelte": "^5.56.1",
		"svelte-check": "^4.6.0",
		"tailwindcss": "^4.3.0",
		"tsx": "^4.23.1",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.60.1",
		"vite": "^8.0.16",
		"vitest": "^4.1.8",
		"vitest-browser-svelte": "^2.1.1"
	},
	"dependencies": {
		"@fontsource/ibm-plex-mono": "^5.3.0",
		"@fontsource/ibm-plex-sans": "^5.3.0",
		"@fontsource/ibm-plex-serif": "^5.3.0",
		"@supabase/ssr": "^0.12.3",
		"@supabase/supabase-js": "^2.110.8"
	}
}
